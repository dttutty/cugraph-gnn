class WholeGraphLogLevel(IntEnum):
    LevFatal = ...
    LevError = ...
    LevWarn = ...
    LevInfo = ...
    LevDebug = ...
    LevTrace = ...

class WholeGraphMemoryAllocType(IntEnum):
    MatNone = ...
    MatDevice = ...
    MatHost = ...
    MatPinned = ...

class WholeGraphDataType(IntEnum):
    DtUnknown = ...
    DtFloat = ...
    DtHalf = ...
    DtDouble = ...
    DtBF16 = ...
    DtInt = ...
    DtInt64 = ...
    DtInt16 = ...
    DtInt8 = ...
    DtCount = ...

class WholeGraphViewType(IntEnum):
    VtNone = ...
    VtLocal = ...
    VtGlobal = ...
    VtRemote = ...

class WholeGraphAccessType(IntEnum):
    AtNone = ...
    AtReadOnly = ...
    AtReadWrite = ...

class WholeGraphOptimizerType(IntEnum):
