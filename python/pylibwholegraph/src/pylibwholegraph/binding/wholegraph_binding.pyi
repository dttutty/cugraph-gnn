class PyMemoryAllocType:
    def __init__(self) -> None: ...
    def set_type(self, new_type: WholeGraphMemoryAllocType) -> None: ...
    def get_type(self) -> int: ...
    def set_ctype(self, alloc_type: int) -> None: ...
    def get_ctype(self) -> int: ...

class GlobalContextWrapper:
    def __init__(self) -> None: ...
    def create_context(
        self,
        temp_create_context_fn: Callable[[Any], Any],
        temp_destroy_context_fn: Callable[[Any, Any], Any],
        temp_malloc_fn: Callable[[tuple[int, ...], int, int, Any, Any], int],
        temp_free_fn: Callable[[Any, Any], Any],
        temp_global_context: Any | None,
        output_malloc_fn: Callable[[tuple[int, ...], int, int, Any, Any], int],
        output_free_fn: Callable[[Any, Any], Any],
        output_global_context: Any | None,
    ) -> None: ...
    def get_env_fns(self) -> int: ...

class PyWholeGraphUniqueID:
    def __init__(self) -> None: ...
    def __len__(self) -> int: ...
    def __dlpack__(self, stream: Any | None = None) -> Any: ...
    def __dlpack_device__(self) -> tuple[int, int]: ...

class PyWholeGraphComm:
    def __init__(self) -> None: ...
    def get_c_handle(self) -> int: ...
    def support_type_location(
        self,
        memory_type: WholeGraphMemoryType,
        memory_location: WholeGraphMemoryLocation,
    ) -> bool: ...
    def get_rank(self) -> int: ...
    def get_size(self) -> int: ...
    def get_clique_info(self) -> tuple[bool, int, int, int, int, int]: ...
    def barrier(self) -> None: ...
    def get_distributed_backend(self) -> WholeGraphDistributedBackend: ...
    def set_distributed_backend(
        self, distributed_backend: WholeGraphDistributedBackend
    ) -> None: ...

class PyWholeGraphHandle:
    def __init__(self) -> None: ...
    def get_c_handle(self) -> int: ...
    def get_communicator(self) -> PyWholeGraphComm: ...
    def get_memory_type(self) -> WholeGraphMemoryType: ...
    def get_memory_location(self) -> WholeGraphMemoryLocation: ...
    def get_global_flatten_tensor(
        self,
        import_dlpack_fn: Callable[[Any], Any],
        data_type: WholeGraphDataType,
        view_from_device: WholeGraphMemoryLocation,
        view_from_device_id: int,
    ) -> tuple[Any, int]: ...
    def get_local_flatten_tensor(
        self,
        import_dlpack_fn: Callable[[Any], Any],
        data_type: WholeGraphDataType,
        view_from_device: WholeGraphMemoryLocation,
        view_from_device_id: int,
    ) -> tuple[Any, int]: ...
    def from_filelist(
        self,
        memory_offset: int,
        memory_entry_size: int,
        file_entry_size: int,
        round_robin_size: int,
        file_list: Sequence[str] | str,
    ) -> None: ...
    def to_file(
        self,
        memory_offset: int,
        memory_entry_size: int,
        file_entry_size: int,
        file_name: str,
    ) -> None: ...

class PyWholeGraphTensorDescription:
    def __init__(self) -> None: ...
    def set_dtype(self, dtype: WholeGraphDataType) -> None: ...
    def set_shape(self, shape: Sequence[int]) -> None: ...
    def set_stride(self, strides: Sequence[int]) -> None: ...
    def set_storage_offset(self, storage_offset: int) -> None: ...
    @property
    def dtype(self) -> WholeGraphDataType: ...
    def dim(self) -> int: ...
    @property
    def shape(self) -> tuple[int, ...]: ...
    def stride(self) -> tuple[int, ...]: ...
    def storage_offset(self) -> int: ...

class WrappedLocalTensor:
    def __init__(self) -> None: ...
    def wrap_tensor(
        self, py_desc: PyWholeGraphTensorDescription, data_ptr: int
    ) -> WrappedLocalTensor: ...
    def get_c_handle(self) -> int: ...

class PyWholeGraphFlattenDlpack:
    def __init__(self) -> None: ...
    def __len__(self) -> int: ...
    def set_view_device(
        self, device_type: WholeGraphMemoryLocation, device_id: int
    ) -> None: ...
    def get_view(
        self,
        handle: PyWholeGraphHandle,
        data_type: WholeGraphDataType,
        view_type: WholeGraphViewType,
        target_rank: int,
    ) -> tuple[int, int]: ...
    @property
    def ptr(self) -> int: ...
    @property
    def __cuda_array_interface__(self) -> dict[str, Any]: ...
    def __dlpack__(self, stream: Any | None = None) -> Any: ...
    def __dlpack_device__(self) -> tuple[int, int]: ...

class PyWholeGraphTensor:
    def __init__(self) -> None: ...
    def get_c_handle(self) -> int: ...
    def get_wholegraph_handle(self) -> PyWholeGraphHandle: ...
    @property
    def dtype(self) -> WholeGraphDataType: ...
    def dim(self) -> int: ...
    @property
    def shape(self) -> tuple[int, ...]: ...
    def stride(self) -> tuple[int, ...]: ...
    def storage_offset(self) -> int: ...
    def get_local_entry_count(self) -> int: ...
    def get_local_entry_start(self) -> int: ...
    def get_sub_tensor(self, starts: Sequence[int], ends: Sequence[int]) -> PyWholeGraphTensor: ...
    def get_tensor_in_window(
        self, flatten_tensor: Any, storage_window_offset: int
    ) -> tuple[Any, int]: ...
    def get_local_tensor(
        self,
        import_dlpack_fn: Callable[[Any], Any],
        view_from_device: WholeGraphMemoryLocation,
        view_from_device_id: int,
    ) -> tuple[Any, int]: ...
    def get_global_tensor(
        self,
        import_dlpack_fn: Callable[[Any], Any],
        view_from_device: WholeGraphMemoryLocation,
        view_from_device_id: int,
    ) -> Any: ...
    def from_filelist(
        self, file_list: Sequence[str] | str, round_robin_size: int = 0
    ) -> None: ...
    def to_file(self, filename: str) -> None: ...

