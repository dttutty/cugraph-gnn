from enum import IntEnum
from typing import Any, Callable, Sequence

class WholeGraphErrorCode(IntEnum):
    Success = ...
    UnknowError = ...
    NotImplemented = ...
    LogicError = ...
    CUDAError = ...
    CommunicationError = ...
    InvalidInput = ...
    InvalidValue = ...
    OutOfMemory = ...
    NotSupported = ...

class WholeGraphMemoryType(IntEnum):
    MtNone = ...
    MtContinuous = ...
    MtDistributed = ...

class WholeGraphMemoryLocation(IntEnum):
    MlNone = ...
    MlDevice = ...
    MlHost = ...

class WholeGraphDistributedBackend(IntEnum):
    DbNone = ...
